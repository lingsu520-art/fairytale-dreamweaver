# 阿里云 RAM 用户 AccessKey（需要有 AliyunSTSAssumeRoleAccess 权限）
ACCESS_KEY_ID=your-access-key-id
ACCESS_KEY_SECRET=your-access-key-secret

# RAM 角色 ARN（格式：acs:ram::账号ID:role/角色名称）
ROLE_ARN=acs:ram::your-account-id:role/oss-upload-role

# STS 临时凭证有效时长（秒），默认 3600
TOKEN_DURATION=3600

# 允许跨域的前端域名，多个用逗号分隔
ALLOWED_ORIGINS=*

# 服务端口
PORT=3001
